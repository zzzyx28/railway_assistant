# ============ Docker 部署用环境变量 ============
# 复制为 .env 后按需修改，再执行 docker compose up -d

# MySQL（与 backend 中 DATABASE_URL 对应）
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=rail_assistant
MYSQL_USER=rail
MYSQL_PASSWORD=rail123

# 知识抽取服务（前端请求该地址，开发时可为 http://localhost:8001）
# VITE_EXTRACT_API=http://localhost:8001

# 后端（JWT、Dify 等）
JWT_SECRET=change-me-in-production
DIFY_API_URL=https://api.dify.ai/v1
DIFY_API_KEY=
DIFY_KNOWLEDGE_API_KEY=
DIFY_USE_WORKFLOW=false
DIFY_WORKFLOW_API_KEY=
