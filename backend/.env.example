# Dify API 根地址（必须以 /v1 结尾）
# 使用 Dify 云：https://api.dify.ai/v1
# 自建 Docker：填你访问 Dify 的地址，例如 http://localhost/v1 或 http://你的服务器IP/v1
DIFY_API_URL=http://localhost/v1
DIFY_API_KEY=your-dify-chat-app-api-key
DIFY_KNOWLEDGE_API_KEY=your-dify-knowledge-api-key

# 智能问答使用工作流时填写（基础流：输入 -> LLM -> 输出）
DIFY_USE_WORKFLOW=false
DIFY_WORKFLOW_API_KEY=
DIFY_WORKFLOW_INPUT_VAR=query
DIFY_WORKFLOW_OUTPUT_VAR=text

JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 使用 MySQL 作为持久化数据库（示例）
DATABASE_URL=mysql+asyncmy://root:123456@localhost:3306/rail_assistant

